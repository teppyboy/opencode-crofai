{
  "name": "@teppyboy/opencode-crofai",
  "version": "1.0.0",
  "description": "Adds CrofAI provider support to OpenCode with automatic model discovery, Lightning naming fix, and reasoning level toggle (Ctrl+T).",
  "author": {
    "name": "teppyboy",
    "email": "teppyboy@users.noreply.github.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teppyboy/opencode-crofai"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test tests",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"tests/**/*.{ts,js}\""
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "8.47.0",
    "@typescript-eslint/parser": "8.47.0",
    "bun-types": "latest",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4"
  }
}
