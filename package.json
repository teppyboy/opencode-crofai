{
  "name": "@tretrauit/opencode-crofai",
  "version": "1.2.5",
  "description": "Adds CrofAI provider support to OpenCode.",
  "author": {
    "name": "tretrauit",
    "email": "contact@tretrauit.me"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./src/plugin.d.ts",
      "import": "./plugin.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teppyboy/opencode-crofai"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test tests",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"tests/**/*.{ts,js}\""
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "8.47.0",
    "@typescript-eslint/parser": "8.47.0",
    "bun-types": "latest",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tretrauit/opencode-crofai": "."
  }
}
